frr version 10.6.1_git
frr defaults traditional
hostname pe2
log stdout informational
!
interface v-p13
 ipv6 ospf6 area 0
 ipv6 ospf6 network point-to-point
exit
!
interface v-p23
 ipv6 ospf6 area 0
 ipv6 ospf6 network point-to-point
exit
!
interface v-p33
 ipv6 ospf6 area 0
exit
!
router ospf6
 ospf6 router-id 5.1.0.0
 log-adjacency-changes
exit
!

frr version 10.6.1_git
frr defaults traditional
hostname pe1
log stdout informational
!
ip router-id 1.1.0.0
!
interface v-p11
 ipv6 ospf6 area 0.0.0.0
 ipv6 ospf6 network point-to-point
exit
!
interface v-p21
 ipv6 ospf6 area 0.0.0.0
 ipv6 ospf6 network point-to-point
exit
!
interface v-p31
 ipv6 ospf6 area 0
exit
!
router ospf6
 ospf6 router-id 1.1.0.0
 log-adjacency-changes
exit
!
